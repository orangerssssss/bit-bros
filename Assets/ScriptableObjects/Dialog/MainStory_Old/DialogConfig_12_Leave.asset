  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_12_Leave
  m_EditorClassIdentifier: 
  contents:
  - name: "\u827E\u514B\u7279"
    content: "\u4E9A\u745F\uFF0C\u6CA1\u60F3\u5230\u4F60\u8FD9\u4E48\u5FEB\u5C31\u8981\u79BB\u5F00\u4E86\u3002\u6211\u8FD8\u8BB0\u5F97\u6885\u6797\u521A\u521A\u628A\u4F60\u9001\u6765\u65F6\uFF0C\u4F60\u8FD8\u662F\u4E2A\u5A74\u513F\uFF0C\u662F\u6751\u91CC\u7684\u4EBA\u4E00\u8D77\u628A\u4F60\u517B\u5927\u7684\u3002\u6211\u4E00\u76F4\u628A\u4F60\u5F53\u4F5C\u4EB2\u751F\u7684\u513F\u5B50\uFF0C\u771F\u4E0D\u820D\u5F97\u4F60\u79BB\u5F00\u3002"
  - name: "\u4E9A\u745F"
    content: "\u8001\u6751\u957F\uFF0C\u6211\u4E5F\u4E0D\u60F3\u79BB\u5F00\uFF0C\u6211\u4ECE\u6765\u6CA1\u6709\u4E00\u4E2A\u4EBA\u53BB\u90A3\u4E48\u8FDC\u7684\u5730\u65B9\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u4F60\u73B0\u5728\u4E0D\u53EA\u662F\u8981\u4FDD\u62A4\u8FD9\u4E2A\u6751\u5B50\u6751\u6C11\u7684\u5B89\u5168\uFF0C\u4E5F\u8981\u8BBE\u6CD5\u53BB\u62EF\u6551\u8FD9\u4E2A\u738B\u56FD\u3002\u53EA\u6709\u4F60\u505A\u4E86\u56FD\u738B\uFF0C\u738B\u56FD\u624D\u4F1A\u6709\u672A\u6765\uFF0C\u8FD9\u4E2A\u9053\u7406\u73B0\u5728\u4F60\u8FD8\u4E0D\u61C2\uFF0C\u4F46\u662F\u5C06\u6765\u4F60\u4F1A\u660E\u767D\u7684\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u4F60\u7684\u8868\u54E5\u51EF\u80FD\u591F\u5E2E\u52A9\u4F60\uFF0C\u53BB\u738B\u57CE\u540E\u4F60\u4E5F\u53EF\u4EE5\u6253\u542C\u4E00\u4E0B\u4ED6\u7684\u4E0B\u843D\uFF0C\u4ED6\u73B0\u5728\u5DF2\u7ECF\u662F\u4E00\u4F4D\u9A91\u58EB\u4E86\uFF0C\u5982\u679C\u6709\u56F0\u96BE\u53EF\u4EE5\u53BB\u627E\u4ED6\u5E2E\u5FD9\u3002\u5E26\u597D\u4F60\u7684\u5175\u5668\u548C\u6CBB\u7597\u5305\uFF0C\u9A6C\u4E0A\u51FA\u53D1\u5427\u3002"
  - name: "\u4E9A\u745F"
    content: "\u597D\u7684\uFF0C\u8001\u6751\u957F\uFF0C\u6211\u4EE5\u540E\u4E00\u5B9A\u4F1A\u56DE\u6765\u770B\u60A8\u3002\u90A3\u6211\u8D70\u4E86\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u51FA\u6751\u7684\u8DEF\u4E0A\u53EF\u80FD\u4F1A\u5C24\u83F2\u65AF\u7684\u624B\u4E0B\uFF0C\u4F60\u53EF\u4EE5\u4ECE\u4E00\u6761\u9690\u79D8\u7684\u5C0F\u8DEF\u51FA\u6751\uFF0C\u8FD9\u6761\u5C0F\u8DEF\u53EA\u6709\u6211\u4EEC\u6751\u91CC\u7684\u5C71\u6C11\u77E5\u9053\uFF0C\u5C31\u5728\u6811\u6797\u65C1\u5DE8\u77F3\u540E\u9762\uFF0C\u4F60\u4E00\u5B9A\u80FD\u627E\u5230\u7684\u3002"
  nextDialog: []
  dialogEvent: Story_12_LeaveVillage
