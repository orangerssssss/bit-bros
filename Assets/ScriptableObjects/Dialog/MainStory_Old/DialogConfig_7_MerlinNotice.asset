  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_7_MerlinNotice
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u8001\u4EBA\u5BB6\uFF0C\u6211\u4ECE\u6765\u6CA1\u6709\u5728\u6751\u91CC\u89C1\u8FC7\u60A8\uFF0C\u8BF7\u95EE\u60A8\u662F\u4EC0\u4E48\u4EBA\uFF1F\u6765\u6211\u4EEC\u8FD9\u4E2A\u504F\u8FDC\u7684\u5C71\u6751\u505A\u4EC0\u4E48\u5462\uFF1F"
  - name: "\u6885\u6797"
    content: "\u4F60\u597D\u5E74\u8F7B\u4EBA\uFF0C\u6211\u662F\u4E00\u540D\u9B54\u6CD5\u5E08\uFF0C\u4F60\u53EF\u4EE5\u53EB\u6211\u9B54\u6CD5\u5E08\u6885\u6797\uFF0C\u6765\u81EA\u738B\u57CE\uFF0C\u6211\u6765\u62DC\u8BBF\u827E\u514B\u7279\u6751\u957F\uFF0C\u6211\u4EEC\u662F\u8001\u670B\u53CB\u4E86\u3002\u4F60\u662F\u4E9A\u745F\u5427\uFF1F\u6211\u542C\u5927\u5BB6\u8BF4\u4F60\u662F\u8FD9\u4E2A\u6751\u5B50\u91CC\u6B66\u827A\u6700\u597D\u7684\u5E74\u8F7B\u4EBA\u3002"
  - name: "\u4E9A\u745F"
    content: "\u9B54\u6CD5\u5E08\u554A\uFF01\u6211\u4ECE\u6765\u6CA1\u6709\u89C1\u8FC7\u9B54\u6CD5\u5E08\u3002\u6211\u4ECE\u5C0F\u548C\u827E\u514B\u7279\u6751\u957F\u5B66\u4E60\u6B66\u827A\uFF0C\u4ED6\u6559\u4F1A\u6211\u5F88\u591A\u3002\u60A8\u4ECE\u5C71\u5916\u6765\uFF0C\u4E00\u5B9A\u89C1\u591A\u8BC6\u5E7F\uFF0C\u60A8\u80FD\u544A\u8BC9\u6211\u4E3A\u4EC0\u4E48\u56FD\u738B\u6CA1\u6709\u7EE7\u627F\u4EBA\u5417\uFF1F\u4E3A\u4EC0\u4E48\u9A91\u58EB\u8001\u7237\u4EEC\u8981\u6BD4\u6B66\u4E89\u738B\u4F4D\u5462\uFF1F"
  - name: "\u6885\u6797"
    content: "\u8BF4\u6765\u8BDD\u957F\uFF0C\u56FD\u738B\u5C24\u745F\u751F\u524D\u628A\u4ED6\u7684\u5723\u5251\u67E5\u5230\u738B\u57CE\u6559\u5802\u524D\u7684\u4E00\u5757\u5927\u77F3\u4E0A\uFF0C\u5BA3\u5E03\u8C01\u80FD\u591F\u62D4\u51FA\u8FD9\u628A\u5251\uFF0C\u5C31\u62E5\u6709\u4ED6\u7684\u8840\u8109\uFF0C\u662F\u738B\u56FD\u7684\u7EE7\u627F\u4EBA\uFF0C\u53EF\u4EE5\u7EE7\u627F\u738B\u4F4D\u3002"
  - name: "\u6885\u6797"
    content: "\u4F46\u662F\u5728\u4ED6\u7A81\u7136\u53BB\u4E16\u540E\uFF0C\u76F4\u5230\u4ECA\u5929\u4E5F\u6CA1\u6709\u4EBA\u80FD\u591F\u62D4\u51FA\u77F3\u4E2D\u5723\u5251\uFF0C\u738B\u56FD\u957F\u671F\u65E0\u4E3B\uFF0C\u5929\u4E0B\u5F00\u59CB\u52A8\u8361\u4E0D\u5B89\uFF0C\u7EB7\u4E89\u56DB\u8D77\uFF0C\u76D7\u8D3C\u6A2A\u884C\uFF0C\u5A01\u5C14\u58EB\u4EBA\u3001\u7231\u5C14\u5170\u4EBA\u3001\u6D77\u5CE1\u5BF9\u9762\u7684\u6CD5\u56FD\u4EBA\u4E5F\u8822\u8822\u6B32\u52A8\uFF0C\u51C6\u5907\u8FDB\u653B\u738B\u56FD\u3002"
  - name: "\u6885\u6797"
    content: "\u738B\u56FD\u6CA1\u6709\u4E86\u56FD\u738B\uFF0C\u9A91\u58EB\u4EEC\u4E5F\u4E0D\u53BB\u626B\u8361\u76D7\u8D3C\uFF0C\u62B5\u6297\u4FB5\u7565\uFF0C\u6BCF\u5929\u4E89\u6267\u4E0D\u4F11\u3002\u6700\u540E\u52BF\u529B\u5F3A\u5927\u7684\u9A91\u58EB\u4EEC\u5546\u8BAE\u7528\u6BD4\u6B66\u6765\u786E\u5B9A\u8C01\u7EE7\u627F\u738B\u4F4D\uFF0C\u5728\u738B\u57CE\u4E3E\u529E\u6BD4\u6B66\u5927\u4F1A\uFF0C\u738B\u56FD\u91CC\u7684\u4EFB\u4F55\u4EBA\u90FD\u53EF\u4EE5\u53C2\u52A0\u3002"
  - name: "\u4E9A\u745F"
    content: "\u554A\uFF0C\u771F\u5E0C\u671B\u80FD\u591F\u770B\u5230\u771F\u6B63\u7684\u9A91\u58EB\u6BD4\u6B66\uFF0C\u827E\u514B\u7279\u6751\u957F\u4EE5\u524D\u4E5F\u662F\u9A91\u58EB\uFF0C\u4ED6\u7ED9\u6211\u8BB2\u4E86\u5F88\u591A\u9A91\u58EB\u7684\u6545\u4E8B\u2026"
  - name: "\u6885\u6797"
    content: "\u6211\u521A\u624D\u5728\u6751\u5916\u770B\u5230\u4F60\u548C\u91CE\u517D\u640F\u6597\uFF0C\u5251\u6CD5\u975E\u5E38\u597D\uFF0C\u6B66\u827A\u9AD8\u8D85\u7684\u9A91\u58EB\u4E5F\u4E0D\u8FC7\u5982\u6B64\u3002\u4F60\u4E0D\u59A8\u4E5F\u53BB\u53C2\u52A0\u6BD4\u6B66\u5927\u4F1A\uFF0C\u8BD5\u8BD5\u62D4\u51FA\u90A3\u628A\u77F3\u4E2D\u5723\u5251\u3002\u4F60\u4E5F\u53EF\u80FD\u6210\u4E3A\u65B0\u7684\u56FD\u738B\u554A\u3002"
  - name: "\u4E9A\u745F"
    content: "\u60A8\u4E0D\u8981\u53D6\u7B11\u6211\u4E86\uFF0C\u6211\u53EA\u662F\u4E00\u4E2A\u5C71\u6751\u7684\u5C11\u5E74\uFF0C\u4ECE\u6CA1\u6709\u79BB\u5F00\u8FC7\u5C71\u91CC\uFF0C\u4E0D\u53EF\u80FD\u6297\u8861\u9A91\u58EB\u7684\u3002\u8C22\u8C22\u60A8\u7684\u6307\u6559\uFF0C\u6211\u8981\u56DE\u53BB\u4E86\uFF0C\u521A\u521A\u6253\u5B8C\u730E\uFF0C\u6211\u6709\u70B9\u7D2F\u4E86\u3002"
  nextDialog: []
  dialogEvent: Story_7_NoticeLeave
