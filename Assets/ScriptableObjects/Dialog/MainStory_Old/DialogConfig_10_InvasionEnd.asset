--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_10_InvasionEnd
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u8FD9\u4E9B\u5F3A\u76D7\u597D\u5389\u5BB3\uFF0C\u4ED6\u4EEC\u6740\u4E86\u6211\u4EEC\u6751\u7684\u4EBA\uFF0C\u70E7\u4E86\u623F\u5B50\uFF0C\u5E78\u4E8F\u6709\u60A8\u5728\u6751\u91CC\uFF0C\u4E0D\u7136\u6751\u5B50\u5C31\u6BC1\u4E86\u3002\u60A8\u7684\u9B54\u6CD5\u592A\u5F3A\u5927\u4E86\uFF01\u592A\u611F\u8C22\u60A8\u4E86\uFF01"
  - name: "\u6885\u6797"
    content: "\u5B69\u5B50\uFF0C\u4F60\u53D7\u4F24\u4E86\u5417\uFF1F\u8FD8\u597D\u6211\u4EEC\u53CA\u65F6\u8D76\u5230\u4E86\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6211\u8FD8\u6491\u5F97\u4F4F\u3002\u4E3A\u4EC0\u4E48\u4F1A\u6709\u8FD9\u4E48\u5389\u5BB3\u7684\u5F3A\u76D7\u6765\u6211\u4EEC\u8FD9\u4E2A\u5C0F\u5C71\u6751\uFF1F\u6751\u91CC\u4EC0\u4E48\u90FD\u6CA1\u6709\uFF0C\u4ED6\u4EEC\u6765\u62A2\u4EC0\u4E48\uFF1F\uFF01"
  - name: "\u6885\u6797"
    content: "\u8FD9\u4E9B\u5F3A\u76D7\u662F\u4F2A\u88C5\u7684\uFF0C\u4F60\u770B\u8FD9\u4E9B\u5175\u5668\u90FD\u662F\u6B63\u89C4\u9A91\u58EB\u56E2\u624D\u7528\u7684\u5175\u5668\uFF0C\u5F3A\u76D7\u53EF\u6CA1\u6709\u8FD9\u4E48\u597D\u7684\u6B66\u827A\u548C\u5175\u5668\u3002"
  - name: "\u4E9A\u745F"
    content: "\u9A91\u58EB\u56E2\uFF1F"
  - name: "\u6885\u6797"
    content: "\u662F\u7684\uFF0C\u4ED6\u4EEC\u5E94\u8BE5\u662F\u9A91\u58EB\u5C24\u83F2\u65AF\u7684\u624B\u4E0B\uFF0C\u662F\u6B63\u89C4\u9A91\u58EB\u56E2\u7684\u58EB\u5175\u3002\u4ED6\u4EEC\u6765\u8FD9\u91CC\u662F\u6765\u6740\u4F60\u7684\uFF0C\u4E3A\u4E86\u63A9\u76D6\u771F\u76F8\u5C31\u51B3\u5B9A\u5C60\u6751\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6740\u6211\uFF1F\uFF01"
  - name: "\u6885\u6797"
    content: "\u5B69\u5B50\uFF0C\u662F\u65F6\u5019\u544A\u8BC9\u4F60\u771F\u6B63\u7684\u8EAB\u4E16\u4E86\u3002\u5C31\u662F\u6211\u5728\u5341\u516B\u5E74\u524D\uFF0C\u628A\u4F60\u9001\u5230\u8FD9\u4E2A\u5C71\u6751\uFF0C\u4EA4\u7ED9\u4F60\u7684\u517B\u7236\uFF0C\u4E5F\u5C31\u662F\u827E\u514B\u7279\u6751\u957F\u629A\u517B\u3002\u4F60\u662F\u8001\u56FD\u738B\u5C24\u745F\u7684\u79C1\u751F\u5B50\uFF0C\u662F\u4ED6\u552F\u4E00\u7684\u5B50\u55E3\uFF0C\u53EA\u6709\u4F60\u624D\u6709\u8D44\u683C\u7EE7\u627F\u738B\u4F4D\u3002"
  - name: "\u6885\u6797"
    content: "\u8FD9\u4EF6\u4E8B\u6211\u8FDE\u827E\u514B\u7279\u90FD\u6CA1\u6709\u544A\u8BC9\uFF0C\u53EA\u6709\u9A91\u58EB\u5C24\u83F2\u65AF\u77E5\u9053\u3002\u4F46\u662F\u5C24\u83F2\u65AF\u5728\u8001\u56FD\u738B\u6B7B\u540E\uFF0C\u4E00\u76F4\u5728\u6697\u4E2D\u8C0B\u5212\u593A\u53D6\u738B\u4F4D\uFF0C\u9664\u6389\u4F60\u624D\u80FD\u4FDD\u8BC1\u4F60\u4E0D\u4F1A\u7A81\u7136\u51FA\u73B0\u5728\u738B\u57CE\uFF0C\u62D4\u51FA\u77F3\u4E2D\u5723\u5251\u2026"
  - name: "\u6885\u6797"
    content: "\u6211\u542C\u8BF4\u4ED6\u5411\u4F60\u4EEC\u6751\u5B50\u6D3E\u51FA\u4E86\u624B\u4E0B\u7684\u4EB2\u4FE1\uFF0C\u5C31\u9A6C\u4E0A\u8D76\u6765\u4E86\uFF0C\u4F46\u662F\u8FD8\u662F\u6CA1\u6709\u80FD\u963B\u6B62\u8FD9\u573A\u707E\u96BE\u7684\u53D1\u751F\u3002"
  - name: "\u4E9A\u745F"
    content: "\u8FD9\u592A\u96BE\u4EE5\u4EE4\u4EBA\u7F6E\u4FE1\u4E86\uFF01\u8001\u6751\u957F\uFF0C\u8FD9\u662F\u771F\u7684\u5417\uFF1F"
  - name: "\u827E\u514B\u7279"
    content: "\u6211\u867D\u7136\u4E5F\u662F\u521A\u521A\u77E5\u9053\u4F60\u7684\u771F\u5B9E\u8EAB\u4E16\uFF0C\u4F46\u662F\u6211\u8BA4\u8BC6\u6885\u6797\u5DF2\u7ECF\u5F88\u591A\u5E74\u4E86\u3002\u4ED6\u662F\u8001\u56FD\u738B\u5C24\u745F\u6700\u4EB2\u5BC6\u7684\u670B\u53CB\uFF0C\u4E5F\u662F\u4E00\u4E2A\u6B63\u76F4\u7684\u4EBA\uFF0C\u6211\u76F8\u4FE1\u4ED6\u8BF4\u7684\u90FD\u662F\u771F\u7684\u3002\u8FD9\u91CC\u518D\u4E5F\u4E0D\u662F\u4E00\u4E2A\u5B89\u5168\u7684\u5730\u65B9\u4E86\uFF0C\u5C24\u83F2\u65AF\u8FBE\u4E0D\u5230\u76EE\u7684\u662F\u4E0D\u4F1A\u7F62\u4F11\u7684\uFF0C\u4ED6\u4F1A\u518D\u6D3E\u66F4\u591A\u7684\u58EB\u5175\u6765\u8FD9\u91CC\uFF0C\u4F60\u5FC5\u987B\u9A6C\u4E0A\u79BB\u5F00\uFF01"
  - name: "\u4E9A\u745F"
    content: "\u79BB\u5F00\uFF1F\u4E0D\uFF0C\u8001\u6751\u957F\uFF0C\u6211\u4E0D\u8D70\uFF0C\u6211\u5728\u8FD9\u91CC\u957F\u5927\uFF0C\u4ECE\u6765\u6CA1\u6709\u79BB\u5F00\u8FC7\u3002\u518D\u8BF4\u6211\u80FD\u53BB\u54EA\u91CC\uFF1F\u6211\u53EA\u8BA4\u8BC6\u6751\u91CC\u7684\u4EBA\u3002"
  - name: "\u6885\u6797"
    content: "\u5B69\u5B50\uFF0C\u4F60\u9700\u8981\u5230\u738B\u57CE\u53BB\uFF0C\u53EA\u6709\u5728\u738B\u57CE\uFF0C\u4F60\u624D\u80FD\u8BC1\u5B9E\u4F60\u7684\u771F\u6B63\u8EAB\u4EFD\uFF0C\u4F60\u624D\u80FD\u593A\u56DE\u5C5E\u4E8E\u4F60\u7684\u738B\u4F4D\u3002\u6211\u4F1A\u5728\u738B\u57CE\u63A5\u5E94\u4F60\uFF0C\u73B0\u5728\u6211\u9700\u8981\u53BB\u8FFD\u8E2A\u5C24\u83F2\u65AF\u7684\u624B\u4E0B\uFF0C\u4F60\u51C6\u5907\u4E00\u4E0B\u9A6C\u4E0A\u4E0A\u8DEF\u5427\uFF01\u4E0D\u8981\u518D\u72B9\u8C6B\u4E86\uFF01\u5230\u738B\u57CE\u6765\u627E\u6211\uFF01"
  - name: "\u827E\u514B\u7279"
    content: "\u4E9A\u745F\uFF0C\u4F60\u9A6C\u4E0A\u628A\u5730\u4E0A\u7684\u6B66\u5668\u548C\u533B\u7597\u5305\u90FD\u6361\u8D77\u6765\uFF0C\u533B\u7597\u5305\u53EF\u4EE5\u5E2E\u52A9\u4F60\u6062\u590D\u5065\u5EB7\uFF0C\u6B66\u5668\u90FD\u62FF\u5230\u94C1\u5320\u90A3\u91CC\uFF0C\u4ED6\u4F1A\u4F30\u4EF7\u6536\u8D2D\u4F60\u5E26\u53BB\u7684\u6B66\u5668\uFF0C\u4ED8\u7ED9\u4F60\u7684\u94B1\u53EF\u4EE5\u4F5C\u4E3A\u4F60\u7684\u8DEF\u8D39\uFF0C\u5B8C\u6210\u8FD9\u4E9B\u4EFB\u52A1\u518D\u6765\u627E\u6211\uFF01"
  nextDialog: []
  dialogEvent: Story_10_MerlinLeft
