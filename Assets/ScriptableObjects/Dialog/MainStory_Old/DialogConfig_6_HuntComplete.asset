  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_6_HuntComplete
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u5C0A\u656C\u7684\u827E\u514B\u7279\u6751\u957F\uFF0C\u8FD9\u662F\u6211\u521A\u521A\u6253\u7684\u517D\u8089\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u592A\u597D\u4E86\uFF0C\u6751\u91CC\u7684\u7CAE\u98DF\u4E0D\u591A\u4E86\uFF0C\u8FD9\u4E9B\u517D\u8089\u80FD\u591F\u5E2E\u52A9\u5927\u5BB6\u6E21\u8FC7\u8FD9\u6BB5\u56F0\u96BE\u7684\u65F6\u5149\u3002\u90A3\u628A\u5251\u600E\u4E48\u6837\uFF1F"
  - name: "\u4E9A\u745F"
    content: "\u8FD9\u628A\u5251\u975E\u5E38\u5408\u624B\uFF01\u91CD\u91CF\u3001\u957F\u77ED\u548C\u91CD\u5FC3\u90FD\u5408\u9002\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u4F60\u8BA9\u6211\u60F3\u8D77\u4E86\u4F60\u54E5\u54E5\u51EF\u5C0F\u65F6\u5019\u7684\u6837\u5B50\uFF0C\u4ED6\u73B0\u5728\u5DF2\u7ECF\u662F\u4E00\u4E2A\u4F1F\u5927\u7684\u9A91\u58EB\u4E86\u3002\u4F60\u4E00\u76F4\u63A5\u53D7\u6B63\u89C4\u7684\u9A91\u58EB\u8BAD\u7EC3\uFF0C\u800C\u4E14\u5F88\u6709\u7EC3\u6B66\u7684\u5929\u8D4B\uFF0C\u73B0\u5728\u7684\u6B66\u827A\u5DF2\u7ECF\u80FD\u591F\u4E0E\u9A91\u58EB\u4EEC\u6297\u8861\u4E86\u3002\u65E9\u665A\u4F60\u4E5F\u8981\u548C\u51EF\u4E00\u6837\u8D70\u51FA\u8FD9\u4E2A\u5C71\u6751\uFF0C\u6210\u4E3A\u4E00\u540D\u8363\u8000\u7684\u9A91\u58EB\uFF0C\u4E3A\u56FD\u738B\u6548\u529B\u3002"
  - name: "\u4E9A\u745F"
    content: "\u662F\u5417\uFF1F\u6211\u4ECE\u8BB0\u4E8B\u662F\u65F6\u5019\u8D77\uFF0C\u4E00\u76F4\u6CA1\u6709\u79BB\u5F00\u8FC7\u8FD9\u7247\u5C71\u533A\uFF0C\u4E5F\u4E0D\u60F3\u5230\u5916\u9762\u53BB\uFF0C\u8FD9\u91CC\u7684\u751F\u6D3B\u867D\u7136\u4E0D\u6613\uFF0C\u4F46\u662F\u5927\u5BB6\u5BF9\u6211\u90FD\u5F88\u597D\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u8BF4\u5230\u5916\u9762\u7684\u4E16\u754C\uFF0C\u521A\u624D\u6765\u4E86\u4E00\u4E2A\u4FE1\u4F7F\uFF0C\u4ED6\u5728\u6751\u53E3\u5F20\u8D34\u4E86\u544A\u793A\uFF0C\u4F60\u53BB\u770B\u770B\u5427\u3002"
  nextDialog: []
  dialogEvent: Story_6_HuntComplete
