  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_3_Hunt
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u65E9\u4E0A\u597D\uFF0C\u5C0A\u656C\u7684\u827E\u514B\u7279\u6751\u957F\uFF01\u60A8\u6709\u4EC0\u4E48\u4E8B\u8981\u627E\u6211\u5417\uFF1F"
  - name: "\u827E\u514B\u7279"
    content: "\u6211\u4EEC\u6751\u91CC\u8981\u7F3A\u7CAE\u4E86\uFF0C\u9700\u8981\u4E00\u4E9B\u517D\u8089\uFF0C\u4F60\u53BB\u6751\u8FB9\u7684\u6811\u6797\u91CC\u6253\u51E0\u53EA\u91CE\u517D\u5427\u3002"
  - name: "\u4E9A\u745F"
    content: "\u597D\uFF01"
  - name: "\u827E\u514B\u7279"
    content: "\u4F60\u7684\u529B\u91CF\u53C8\u6709\u4E86\u8FDB\u6B65\uFF0C\u539F\u6765\u7684\u5175\u5668\u5DF2\u7ECF\u592A\u8F7B\u4E86\u3002\u4E0A\u6B21\u4F60\u548C\u6211\u8981\u4E00\u628A\u5251\uFF0C\u6211\u5C31\u8BA9\u6751\u91CC\u7684\u94C1\u5320\u6253\u9020\u4E86\u4E00\u628A\u65B0\u7684\u5251\u7ED9\u4F60\uFF0C\u6B63\u597D\u4ECA\u5929\u5251\u5DF2\u7ECF\u505A\u597D\u4E86\uFF0C\u653E\u5728\u90A3\u8FB9\uFF0C\u4F60\u62FF\u53BB\u8BD5\u8BD5\uFF0C\u770B\u662F\u4E0D\u662F\u5408\u624B\u3002"
  - name: "\u4E9A\u745F"
    content: "\u8C22\u8C22\u6751\u957F\uFF01\u60A8\u5BF9\u6211\u592A\u597D\u4E86\uFF01"
  nextDialog: []
  dialogEvent: Story_3_GetMeat
