  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_0_0
  m_EditorClassIdentifier: 
  contents:
  - name: "\u6751\u6C11"
    content: "\u65E9\u5B89\uFF0C\u4E9A\u745F\uFF01\u4ECA\u5929\u7684\u72E9\u730E\u6536\u83B7\u5982\u4F55\uFF1F"
  - name: "\u4E9A\u745F"
    content: "\u65E9\u5B89\uFF0C\u6770\u514B\u3002\u4ECA\u5929\u8FD0\u6C14\u4E0D\u9519\uFF0C\u6355\u5230\u4E86\u51E0\u53EA\u5154\u5B50\u548C\u4E00\u53EA\u9E7F\u3002"
  - name: "\u6751\u6C11"
    content: "\u4E9A\u745F\uFF0C\u4F60\u603B\u662F\u80FD\u5E26\u56DE\u6700\u597D\u7684\u730E\u7269\u3002\u4F60\u7684\u5251\u672F\u548C\u5C04\u672F\u662F\u5728\u54EA\u91CC\u5B66\u7684\uFF1F"
  - name: "\u4E9A\u745F"
    content: "\u8FD9\u5168\u5F97\u611F\u8C22\u827E\u514B\u7279\u5148\u751F\u3002\u4ED6\u6559\u4E86\u6211\u6240\u6709\u7684\u6280\u827A\u3002"
  - name: "\u6751\u6C11"
    content: "\u4E9A\u745F\uFF0C\u4F60\u771F\u662F\u6211\u4EEC\u6751\u5B50\u7684\u9A84\u50B2\u3002\u6BCF\u6B21\u770B\u5230\u4F60\u6253\u56DE\u6765\u7684\u730E\u7269\uFF0C\u90FD\u60F3\u8D77\u51EF\uFF0C\u4ED6\u73B0\u5728\u5DF2\u7ECF\u662F\u9A91\u58EB\u4E86\u3002"
  - name: "\u4E9A\u745F"
    content: "\u8C22\u8C22\u4F60\u3002\u6211\u53EA\u662F\u5C3D\u6211\u6240\u80FD\u5E2E\u52A9\u6751\u5E84\u800C\u5DF2\u3002"
  - name: "\u6751\u6C11"
    content: "\u5BF9\u4E86\uFF0C\u4E9A\u745F\uFF0C\u4F60\u7236\u4EB2\u827E\u514B\u7279\u5148\u751F\u627E\u4F60\uFF0C\u4F3C\u4E4E\u6709\u4E9B\u91CD\u8981\u7684\u4E8B\u60C5\u8981\u8DDF\u4F60\u8BF4\u3002"
  - name: "\u4E9A\u745F"
    content: "\u662F\u5417\uFF1F\u6211\u9A6C\u4E0A\u53BB\u627E\u4ED6\u3002\u8C22\u8C22\u4F60\u544A\u8BC9\u6211\uFF0C\u6770\u514B\u3002"
  - name: "\u6751\u6C11"
    content: "\u53BB\u5427\uFF0C\u4E9A\u745F\uFF0C\u5E0C\u671B\u4E00\u5207\u90FD\u597D\u3002"
  nextDialog: []
