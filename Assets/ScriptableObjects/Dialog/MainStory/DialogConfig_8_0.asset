  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_8_0
  m_EditorClassIdentifier: 
  contents:
  - name: "\u827E\u514B\u7279"
    content: "\u4E9A\u745F\uFF0C\u6211\u7684\u5B69\u5B50\uFF0C\u5F53\u6211\u7B2C\u4E00\u6B21\u62B1\u8D77\u4F60\u65F6\uFF0C\u5C31\u77E5\u9053\u4F60\u6CE8\u5B9A\u4F1A\u6709\u4E0D\u51E1\u7684\u547D\u8FD0\u3002\u6211\u4E00\u76F4\u628A\u4F60\u5F53\u4F5C\u6211\u7684\u4EB2\u751F\u513F\u5B50\u517B\u80B2\uFF0C\u770B\u7740\u4F60\u4ECE\u4E00\u4E2A\u8C03\u76AE\u7684\u5B69\u5B50\u6210\u957F\u4E3A\u5982\u4ECA\u8FD9\u6837\u52C7\u6562\u7684\u9752\u5E74\uFF0C\u6211\u7684\u5FC3\u4E2D\u65E2\u611F\u5230\u9A84\u50B2\uFF0C\u53C8\u5145\u6EE1\u4E86\u4E0D\u820D\u3002"
  - name: "\u4E9A\u745F"
    content: "\u827E\u514B\u7279\u5148\u751F\uFF0C\u60A8\u7ED9\u4E86\u6211\u4E00\u4E2A\u5BB6\uFF0C\u6559\u4F1A\u4E86\u6211\u52C7\u6C14\u548C\u6B63\u76F4\u3002\u6211\u6C38\u8FDC\u4E0D\u4F1A\u5FD8\u8BB0\u60A8\u5BF9\u6211\u7684\u6069\u60C5\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u6211\u77E5\u9053\uFF0C\u4F60\u73B0\u5728\u5FC5\u987B\u53BB\u8FFD\u6C42\u4F60\u7684\u547D\u8FD0\u3002\u4F46\u65E0\u8BBA\u4F60\u8D70\u5230\u54EA\u91CC\uFF0C\u8BB0\u4F4F\uFF0C\u8FD9\u4E2A\u6751\u5E84\u6C38\u8FDC\u662F\u4F60\u7684\u5BB6\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u8FD8\u6709\uFF0C\u4E00\u5B9A\u8981\u627E\u5230\u6211\u7684\u513F\u5B50\u51EF\uFF0C\u51EF\u9A91\u58EB\u3002\u4ED6\u5728\u738B\u57CE\u4E2D\u6709\u7740\u4E00\u5E2D\u4E4B\u5730\uFF0C\u662F\u4E2A\u52C7\u6562\u548C\u667A\u6167\u7684\u9A91\u58EB\u3002\u4ED6\u4F1A\u6210\u4E3A\u4F60\u5728\u738B\u57CE\u7684\u53EF\u9760\u76DF\u53CB\uFF0C\u5E2E\u52A9\u4F60\u9762\u5BF9\u5373\u5C06\u5230\u6765\u7684\u6311\u6218\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6211\u4F1A\u627E\u5230\u51EF\u9A91\u58EB\u3002\u6211\u4F1A\u8BB0\u4F4F\u60A8\u7684\u8BDD\uFF0C\u827E\u514B\u7279\u5148\u751F\u3002\u6211\u4E00\u5B9A\u4F1A\u56DE\u6765\uFF0C\u5E26\u7740\u80DC\u5229\u7684\u6D88\u606F\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u6211\u76F8\u4FE1\u4F60\uFF0C\u4E9A\u745F\u3002\u4F60\u7684\u52C7\u6C14\u548C\u51B3\u5FC3\u5C06\u5F15\u9886\u4F60\u8D70\u5411\u4F1F\u5927\u7684\u547D\u8FD0\u3002\u4F46\u8981\u5C0F\u5FC3\uFF0C\u8DEF\u9014\u4E0A\u5145\u6EE1\u4E86\u672A\u77E5\u548C\u5371\u9669\u3002\u8BB0\u4F4F\uFF0C\u6C38\u8FDC\u4FDD\u6301\u8C26\u900A\u548C\u667A\u6167\uFF0C\u5C31\u50CF\u4F60\u5728\u8FD9\u4E2A\u6751\u5E84\u91CC\u5B66\u5230\u7684\u4E00\u6837\u3002\u51FA\u6751\u7684\u8DEF\u4E0A\u53EF\u80FD\u4F1A\u5C24\u83F2\u65AF\u7684\u624B\u4E0B\uFF0C\u4F60\u53EF\u4EE5\u4ECE\u4E00\u6761\u9690\u79D8\u7684\u5C0F\u8DEF\u51FA\u6751\uFF0C\u8FD9\u6761\u5C0F\u8DEF\u53EA\u6709\u6211\u4EEC\u6751\u91CC\u7684\u5C71\u6C11\u77E5\u9053\uFF0C\u5C31\u5728\u5893\u5730\u7684\u540E\u9762\uFF0C\u4F60\u4E00\u5B9A\u80FD\u627E\u5230\u7684\u3002"
  nextDialog: []
  dialogEvent: 
