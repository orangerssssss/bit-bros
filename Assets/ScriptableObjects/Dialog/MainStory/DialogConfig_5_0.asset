  contents:
  - name: "\u4E9A\u745F"
    content: "\u827E\u514B\u7279\u5148\u751F\uFF0C\u6211\u6709\u7D27\u6025\u7684\u4E8B\u60C5\u8981\u544A\u8BC9\u60A8\uFF01"
  - name: "\u827E\u514B\u7279"
    content: "\u4E9A\u745F\uFF0C\u600E\u4E48\u4E86\uFF1F\u4F60\u770B\u8D77\u6765\u5F88\u7740\u6025\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6885\u6797\u5148\u751F\u6765\u5230\u4E86\u6211\u4EEC\u6751\u5E84\uFF0C\u4ED6\u5E26\u6765\u4E86\u4E00\u4E2A\u574F\u6D88\u606F\u3002\u6709\u4E00\u7FA4\u5F3A\u76D7\u6253\u7B97\u6765\u62A2\u593A\u6211\u4EEC\u6751\u5B50\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u6885\u6797\uFF1F\u4ED6\u6765\u4E86\uFF1F\u5728\u54EA\u91CC\uFF1F\u8FD9\u7684\u786E\u662F\u4E2A\u574F\u6D88\u606F\u3002\u6211\u9A6C\u4E0A\u53BB\u89C1\u4ED6\u3002\u540C\u65F6\uFF0C\u4F60\u9700\u8981\u8D76\u5FEB\u51C6\u5907\u6B66\u5668\uFF0C\u4FDD\u62A4\u6751\u6C11\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6211\u660E\u767D\u4E86\uFF0C\u6211\u4F1A\u5C3D\u5FEB\u884C\u52A8\u3002"
  nextDialog: []
  dialogEvent: 
