  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_5_2
  m_EditorClassIdentifier: 
  contents:
  - name: "\u6751\u6C11"
    content: "\u4E9A\u745F\uFF01\u4E9A\u745F\uFF01\u5F3A\u76D7\u5DF2\u7ECF\u8FDB\u6751\u4E86\uFF0C\u4ED6\u4EEC\u5728\u6740\u4EBA\u653E\u706B\uFF01"
  - name: "\u4E9A\u745F"
    content: "\u4EC0\u4E48\uFF1F\u5DF2\u7ECF\u6765\u4E86\uFF1F"
  - name: "\u6751\u6C11"
    content: "\u662F\u7684\uFF0C\u8D76\u5FEB\u6551\u4EBA\uFF01\u4F60\u5FC5\u987B\u5FEB\u70B9\u6765\u5E2E\u52A9\u6211\u4EEC\uFF01"
  - name: "\u6751\u6C11"
    content: "\u4E9A\u745F\uFF0C\u4F60\u53EF\u4EE5\u53EC\u96C6\u5176\u4ED6\u6751\u6C11\u4E00\u8D77\u6253\u5F3A\u76D7\uFF1B\u4F60\u7684\u670B\u53CB\u4EEC\u90FD\u5F88\u52C7\u6562\uFF0C\u4F46\u662F\u4E0D\u662F\u6BCF\u4E2A\u4EBA\u90FD\u6709\u6B66\u5668\uFF0C\u4ED6\u4EEC\u53EF\u80FD\u4F1A\u8D64\u624B\u7A7A\u62F3\u9762\u5BF9\u5F3A\u76D7\uFF0C\u5F88\u53EF\u80FD\u4F1A\u88AB\u6740\u3002"
  - name: "\u4E9A\u745F"
    content: "\u4F46\u5982\u679C\u6211\u4E0D\u53EC\u96C6\u6751\u6C11\uFF0C\u6211\u5C31\u5F97\u72EC\u81EA\u5BF9\u6297\u4E00\u7FA4\u5F3A\u76D7\u3002\u90A3\u6837\u7684\u8BDD\uFF0C\u6211\u53EF\u80FD\u4F1A\u2026"
  - name: "\u6751\u6C11"
    content: "\u6211\u4EEC\u77E5\u9053\u4F60\u662F\u52C7\u58EB\uFF0C\u4E9A\u745F\u3002\u4F46\u4F60\u4E5F\u662F\u6211\u4EEC\u8FD9\u4E2A\u6751\u5E84\u7684\u5E0C\u671B\u3002\u65E0\u8BBA\u600E\u6837\u6211\u4EEC\u90FD\u4F1A\u652F\u6301\u4F60\u3002"
  - name: "\u4E9A\u745F"
    content: "\u65E0\u8BBA\u5982\u4F55\uFF0C\u6211\u4E0D\u80FD\u8BA9\u6751\u5B50\u9677\u5165\u5371\u9669\u3002\u6211\u5FC5\u987B\u91C7\u53D6\u884C\u52A8\uFF01"
  nextDialog:
  - optionName: "\u72EC\u81EA\u51FB\u8D25\u5F3A\u76D7"
    dialog: {fileID: 11400000, guid: 355cc7d751f16414cb4291f490427096, type: 2}
  - optionName: "\u8054\u5408\u6751\u6C11\u51FB\u8D25\u5F3A\u76D7"
    dialog: {fileID: 11400000, guid: d8d9d55eddce77c4ab0368aea2d1720d, type: 2}
