  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_4_0
  m_EditorClassIdentifier: 
  contents:
  - name: "\u8001\u4EBA"
    content: "\u6211\u662F\u6885\u6797\uFF0C\u4E00\u4E2A\u9B54\u6CD5\u5E08\u3002\u6211\u6765\u8FD9\u91CC\u662F\u4E3A\u4E86\u62DC\u8BBF\u6211\u7684\u8001\u670B\u53CB\u827E\u514B\u7279\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6885\u6797\u5148\u751F\uFF0C\u60A8\u8BF4\u7684\u662F\u771F\u7684\u5417\uFF1F\u60A8\u771F\u7684\u662F\u9B54\u6CD5\u5E08\uFF1F\u6211\u4EEC\u4ECE\u672A\u89C1\u8FC7\u9B54\u6CD5\u5E08\uFF01"
  - name: "\u6885\u6797"
    content: "\u6211\u662F\u3002\u6211\u6709\u4E00\u4E9B\u91CD\u8981\u7684\u4E8B\u60C5\u8981\u544A\u8BC9\u5927\u5BB6\u3002\u5173\u4E8E\u6211\u4EEC\u7684\u56FD\u738B\u5C24\u745F\u548C\u4ED6\u7684\u5723\u5251\u3002"
  - name: "\u4E9A\u745F"
    content: "\u5723\u5251\uFF1F\u662F\u5173\u4E8E\u77F3\u4E2D\u5251\u7684\u6545\u4E8B\u5417\uFF1F"
  - name: "\u6885\u6797"
    content: "\u6CA1\u9519\u3002\u56FD\u738B\u5C24\u745F\u751F\u524D\u5C06\u4ED6\u7684\u5723\u5251\u63D2\u5165\u738B\u57CE\u6559\u5802\u524D\u7684\u4E00\u5757\u5927\u77F3\u4E2D\uFF0C\u5BA3\u5E03\u8C01\u80FD\u62D4\u51FA\u8FD9\u628A\u5251\uFF0C\u5C31\u662F\u4ED6\u7684\u8840\u8109\uFF0C\u738B\u56FD\u7684\u5408\u6CD5\u7EE7\u627F\u4EBA\u3002\u4F46\u81EA\u4ECE\u56FD\u738B\u7A81\u7136\u53BB\u4E16\u4EE5\u540E\uFF0C\u81F3\u4ECA\u6CA1\u6709\u4EBA\u80FD\u591F\u62D4\u51FA\u77F3\u4E2D\u5723\u5251\u3002\u56E0\u6B64\uFF0C\u738B\u56FD\u957F\u671F\u65E0\u4E3B\uFF0C\u52A8\u8361\u4E0D\u5B89\uFF0C\u7EB7\u4E89\u56DB\u8D77\uFF0C\u76D7\u8D3C\u6A2A\u884C\u3002"
  - name: "\u6885\u6797"
    content: "\u6211\u4EEC\u7684\u90BB\u56FD\u5A01\u5C14\u58EB\u4EBA\u3001\u7231\u5C14\u5170\u4EBA\u3001\u751A\u81F3\u6D77\u5CE1\u5BF9\u9762\u7684\u6CD5\u56FD\u4EBA\u90FD\u5728\u89CA\u89CE\u6211\u4EEC\u7684\u571F\u5730\u3002\u6CA1\u6709\u56FD\u738B\uFF0C\u9A91\u58EB\u4EEC\u4E5F\u4E0D\u53BB\u626B\u8361\u76D7\u8D3C\uFF0C\u62B5\u6297\u4FB5\u7565\u3002\u4ED6\u4EEC\u6BCF\u5929\u53EA\u662F\u5728\u4E89\u6267\u4E0D\u4F11\u3002"
  - name: "\u4E9A\u745F"
    content: "\u8FD9\u771F\u662F\u7CDF\u7CD5\u7684\u6D88\u606F\uFF01"
  - name: "\u6885\u6797"
    content: "\u73B0\u5728\uFF0C\u738B\u56FD\u91CC\u6700\u5F3A\u5927\u7684\u9A91\u58EB\u4EEC\u51B3\u5B9A\u7528\u6BD4\u6B66\u7684\u65B9\u5F0F\u6765\u786E\u5B9A\u65B0\u7684\u56FD\u738B\u3002\u6BD4\u6B66\u5927\u4F1A\u5373\u5C06\u5728\u738B\u57CE\u4E3E\u529E\uFF0C\u4EFB\u4F55\u4EBA\u90FD\u53EF\u4EE5\u53C2\u52A0\u3002\u4E9A\u745F\uFF0C\u6211\u542C\u5927\u5BB6\u90FD\u79F0\u8D5E\u4F60\u6B66\u827A\u5F88\u597D\uFF0C\u6211\u8BA4\u4E3A\u4F60\u7684\u6B66\u827A\u8DB3\u4EE5\u8D62\u5F97\u8FD9\u573A\u6BD4\u6B66\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6211\uFF1F\u4F46\u662F\u6211\u53EA\u662F\u4E00\u4E2A\u666E\u901A\u7684\u730E\u4EBA\u2026"
  - name: "\u6885\u6797"
    content: "\u4F60\u662F\u4E00\u4F4D\u52C7\u6562\u548C\u6709\u624D\u534E\u7684\u5E74\u8F7B\u4EBA\u3002\u6211\u76F8\u4FE1\uFF0C\u4F60\u6709\u80FD\u529B\u8D62\u5F97\u6BD4\u6B66\uFF0C\u751A\u81F3\u53EF\u80FD\u6210\u4E3A\u65B0\u7684\u56FD\u738B\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6885\u6797\u5148\u751F\uFF0C\u6211\u5F88\u611F\u6FC0\u60A8\u7684\u9080\u8BF7\uFF0C\u4F46\u6211\u5FC5\u987B\u62D2\u7EDD\u3002\u6211\u559C\u6B22\u8FD9\u4E2A\u5C71\u6751\u7684\u5E73\u9759\u751F\u6D3B\uFF0C\u6211\u4E5F\u820D\u4E0D\u5F97\u79BB\u5F00\u827E\u514B\u7279\u5148\u751F\u548C\u6211\u7684\u670B\u53CB\u4EEC\u3002"
  - name: "\u6885\u6797"
    content: "\u6211\u5C0A\u91CD\u4F60\u7684\u9009\u62E9\uFF0C\u4E9A\u745F\u3002\u4E00\u4E2A\u4EBA\u7684\u751F\u6D3B\u9009\u62E9\u662F\u975E\u5E38\u4E2A\u4EBA\u7684\u4E8B\u60C5\u3002\u4F46\u5728\u6B64\u4E4B\u524D\uFF0C\u6211\u8FD8\u6709\u4E00\u4E2A\u4E0D\u592A\u597D\u7684\u6D88\u606F\u9700\u8981\u544A\u8BC9\u4F60\u3002"
  - name: "\u4E9A\u745F"
    content: "\u4EC0\u4E48\u6D88\u606F\uFF1F"
  - name: "\u6885\u6797"
    content: "\u6211\u6765\u8FD9\u91CC\u7684\u8DEF\u4E0A\uFF0C\u542C\u8BF4\u6709\u4E00\u7FA4\u5F3A\u76D7\u6B63\u5728\u8BA1\u5212\u62A2\u593A\u4F60\u4EEC\u6751\u5B50\u3002\u4ED6\u4EEC\u53EF\u80FD\u5F88\u5FEB\u5C31\u4F1A\u6765\u5230\u8FD9\u91CC\u3002"
  - name: "\u4E9A\u745F"
    content: "\u5F3A\u76D7\uFF1F\u8FD9\u53EF\u4E0D\u662F\u597D\u6D88\u606F\u3002\u6211\u4EEC\u5FC5\u987B\u7ACB\u523B\u901A\u77E5\u827E\u514B\u7279\u5148\u751F\u548C\u5176\u4ED6\u6751\u6C11\uFF0C\u51C6\u5907\u5E94\u5BF9\u3002"
  - name: "\u6885\u6797"
    content: "\u662F\u7684\uFF0C\u4F60\u4EEC\u5FC5\u987B\u5C3D\u5FEB\u505A\u597D\u51C6\u5907\u3002\u8FD9\u4E9B\u5F3A\u76D7\u53EF\u80FD\u4E0D\u4F1A\u624B\u4E0B\u7559\u60C5\u3002"
  nextDialog: []
