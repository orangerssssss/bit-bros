  contents:
  - name: "\u4E9A\u745F"
    content: "\u4F60\u662F......\u52A0\u96F7\u65AF\uFF1F\n"
  - name: "\u52A0\u96F7\u65AF"
    content: "\uFF08\u75DB\u82E6\u5730\u7741\u5F00\u773C\uFF09"
  - name: "\u52A0\u96F7\u65AF"
    content: "......\u4E9A\u745F\uFF1F"
  - name: "\u4E9A\u745F"
    content: "\u4F60\u8BA4\u8BC6\u6211\uFF1F\u6211\u662F\u4E9A\u745F\uFF0C\u4F46\u662F\u6211\u4E0D\u6E05\u695A\u81EA\u5DF1\u6765\u81EA\u6765\u54EA\u3002"
  - name: "\u4E9A\u745F"
    content: "\u53EA\u662F\u6709\u4E2A\u795E\u79D8\u7684\u58F0\u97F3\u6307\u5F15\u6211\u524D\u6765\u3002"
  - name: "\u52A0\u96F7\u65AF"
    content: "\u4E0D\u8981......\u76F8\u4FE1......\u6885\u6797......"
  - name: "\u4E9A\u745F"
    content: "\uFF08\u4ED6\u600E\u4E48\u77E5\u9053\u6885\u6797\uFF1F\uFF09"
  - name: "\u52A0\u96F7\u65AF"
    content: "\u4F60\u662F\u8001\u56FD\u738B\u7684\u79C1\u751F\u5B50......"
  - name: "\u52A0\u96F7\u65AF"
    content: "\u62D4\u51FA......\u5251\uFF0C\u4E16\u754C......\u8FD8\u662F\u4F1A\u9677\u5165\u9ED1\u6697\u7684\u5FAA\u73AF......\u54B3\u54B3......"
  - name: "\u52A0\u96F7\u65AF"
    content: "\u4E0D\u8981......\u4E0D\u8981......\u54B3\u54B3"
  - name: "\u4E9A\u745F"
    content: "\u4E0D\u8981\u4EC0\u4E48?"
  - name: "\u52A0\u96F7\u65AF"
    content: ......
  - name: "\u4E9A\u745F"
    content: "\uFF08\u4ED6\u4F3C\u4E4E\u5DF2\u7ECF\u65AD\u6C14\u4E86\uFF09"
  - name: "\u4E9A\u745F"
    content: "\u6211\u662F\u79C1\u751F\u5B50\uFF1F"
  - name: "\u4E9A\u745F"
    content: "\u4ED6\u8BF4\u7684\u7A76\u7ADF\u662F\u4EC0\u4E48\uFF0C\u6885\u6797\u7A76\u7ADF\u6709\u4EC0\u4E48\u76EE\u7684......."
  nextDialog: []
