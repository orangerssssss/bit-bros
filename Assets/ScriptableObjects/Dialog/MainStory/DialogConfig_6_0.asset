--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_6_0
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u8FD9\u4E9B\u5F3A\u76D7\u592A\u6B8B\u5FCD\u4E86\uFF0C\u4ED6\u4EEC\u6740\u5BB3\u4E86\u6211\u4EEC\u7684\u670B\u53CB\uFF0C\u711A\u70E7\u4E86\u6211\u4EEC\u7684\u5BB6\u56ED\u3002\u5E78\u4E8F\u6709\u60A8\u5728\uFF0C\u6885\u6797\u5148\u751F\uFF0C\u60A8\u7684\u9B54\u6CD5\u592A\u5F3A\u5927\u4E86\uFF01\u592A\u611F\u8C22\u60A8\u4E86\uFF01"
  - name: "\u6885\u6797"
    content: "\u5B69\u5B50\uFF0C\u4F60\u53D7\u4F24\u4E86\u5417\uFF1F\u6211\u4EEC\u53CA\u65F6\u8D76\u5230\u8FD8\u662F\u597D\u7684\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6211\u8FD8\u6491\u5F97\u4F4F\u3002\u8FD9\u4E9B\u5F3A\u76D7\u4E3A\u4EC0\u4E48\u8FD9\u4E48\u5F3A\u5927\uFF1F\u6211\u4EEC\u7684\u6751\u5B50\u5E76\u6CA1\u6709\u4EC0\u4E48\u503C\u5F97\u4ED6\u4EEC\u6765\u62A2\u593A\u7684\uFF01"
  - name: "\u6885\u6797"
    content: "\u4E9A\u745F\uFF0C\u8FD9\u4E9B\u6240\u8C13\u7684\u5F3A\u76D7\u5176\u5B9E\u662F\u4F2A\u88C5\u7684\u3002\u770B\u770B\u8FD9\u4E9B\u5175\u5668\uFF0C\u8FD9\u90FD\u662F\u6B63\u89C4\u9A91\u58EB\u56E2\u624D\u80FD\u914D\u5907\u7684\u3002\u666E\u901A\u7684\u5F3A\u76D7\u662F\u4E0D\u4F1A\u6709\u8FD9\u6837\u7684\u6B66\u827A\u548C\u88C5\u5907\u7684\u3002"
  - name: "\u4E9A\u745F"
    content: "\u9A91\u58EB\u56E2\uFF1F"
  - name: "\u6885\u6797"
    content: "\u6CA1\u9519\uFF0C\u4ED6\u4EEC\u662F\u9A91\u58EB\u5C24\u83F2\u65AF\u7684\u624B\u4E0B\uFF0C\u4E13\u4E1A\u7684\u58EB\u5175\u3002\u4ED6\u4EEC\u6765\u8FD9\u91CC\u7684\u76EE\u7684\u662F\u8981\u6740\u6B7B\u4F60\uFF0C\u4E3A\u4E86\u63A9\u76D6\u771F\u76F8\uFF0C\u4ED6\u4EEC\u9009\u62E9\u5C60\u6740\u6574\u4E2A\u6751\u5E84\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6740\u6211\uFF1F\u4F46\u4E3A\u4EC0\u4E48\uFF1F"
  - name: "\u6885\u6797"
    content: "\u5B69\u5B50\uFF0C\u73B0\u5728\u662F\u65F6\u5019\u544A\u8BC9\u4F60\u771F\u76F8\u4E86\u3002\u4F60\u662F\u56FD\u738B\u5C24\u745F\u7684\u79C1\u751F\u5B50\uFF0C\u552F\u4E00\u7684\u5408\u6CD5\u7EE7\u627F\u4EBA\u3002\u4E3A\u4E86\u4FDD\u62A4\u4F60\uFF0C\u6211\u4EEC\u4E00\u76F4\u6CA1\u6709\u544A\u8BC9\u4F60\u771F\u5B9E\u8EAB\u4EFD\u3002\u5C24\u83F2\u65AF\u4E00\u76F4\u5728\u6697\u4E2D\u8C0B\u5212\u593A\u53D6\u738B\u4F4D\uFF0C\u4F60\u7684\u5B58\u5728\u5BF9\u4ED6\u6765\u8BF4\u662F\u4E00\u4E2A\u5DE8\u5927\u7684\u5A01\u80C1\u3002\u6211\u542C\u8BF4\u4ED6\u6D3E\u51FA\u4E86\u4ED6\u7684\u624B\u4E0B\u79D8\u5BC6\u5411\u4F60\u7684\u5C71\u6751\u8D76\u6765\uFF0C\u6211\u5C31\u77E5\u9053\u4ED6\u8981\u88AD\u51FB\u4F60\uFF0C\u4E8E\u662F\u6211\u9A6C\u4E0A\u542F\u7A0B\u8D76\u6765\u3002"
  - name: "\u4E9A\u745F"
    content: "\u8FD9\u2026\u8FD9\u592A\u96BE\u4EE5\u76F8\u4FE1\u4E86\uFF01\u827E\u514B\u7279\u5148\u751F\uFF0C\u8FD9\u662F\u771F\u7684\u5417\uFF1F"
  - name: "\u827E\u514B\u7279"
    content: "\u867D\u7136\u6211\u4E5F\u662F\u521A\u77E5\u9053\u8FD9\u4E2A\u6D88\u606F\uFF0C\u4F46\u6211\u76F8\u4FE1\u6885\u6797\u3002\u4ED6\u662F\u5C24\u745F\u56FD\u738B\u6700\u4EB2\u5BC6\u7684\u670B\u53CB\uFF0C\u4E00\u4E2A\u6B63\u76F4\u7684\u4EBA\u3002\u73B0\u5728\uFF0C\u4F60\u5728\u8FD9\u91CC\u5DF2\u7ECF\u4E0D\u518D\u5B89\u5168\uFF0C\u4F60\u5FC5\u987B\u79BB\u5F00\u8FD9\u91CC\u3002"
  - name: "\u4E9A\u745F"
    content: "\u79BB\u5F00\uFF1F\u4E0D\uFF0C\u6211\u4E0D\u80FD\u79BB\u5F00\u6211\u7684\u670B\u53CB\u3002"
  - name: "\u6885\u6797"
    content: "\u4E9A\u745F\uFF0C\u4F60\u5FC5\u987B\u53BB\u738B\u57CE\u3002\u53EA\u6709\u90A3\u91CC\uFF0C\u4F60\u624D\u80FD\u8BC1\u660E\u4F60\u7684\u771F\u6B63\u8EAB\u4EFD\uFF0C\u593A\u56DE\u4F60\u7684\u738B\u4F4D\u3002\u53EA\u6709\u8FD9\u6837\uFF0C\u8FD9\u4E2A\u6751\u5E84\u3001\u6211\u4EEC\u7684\u738B\u56FD\u3001\u8FD8\u6709\u4F60\uFF0C\u624D\u4F1A\u6709\u771F\u6B63\u7684\u5B89\u5168\u3002\u73B0\u5728\uFF0C\u6211\u5FC5\u987B\u53BB\u8FFD\u8E2A\u5C24\u83F2\u65AF\u7684\u624B\u4E0B\u3002\u4F60\u51C6\u5907\u597D\uFF0C\u5C3D\u5FEB\u51FA\u53D1\u5427\uFF01"
  - name: "\u827E\u514B\u7279"
    content: "\u4E9A\u745F\uFF0C\u5FEB\u53BB\u6536\u96C6\u5730\u4E0A\u7684\u6B66\u5668\u548C\u836F\u54C1\u3002\u8FD9\u4E9B\u90FD\u662F\u4F60\u7684\uFF0C\u53EF\u4EE5\u5728\u65C5\u9014\u4E2D\u4E3A\u4F60\u63D0\u4F9B\u5E2E\u52A9\u3002\u628A\u591A\u4F59\u7684\u6B66\u5668\u62FF\u7ED9\u94C1\u5320\uFF0C\u4ED6\u4F1A\u7ED9\u4F60\u4E00\u4E9B\u94B1\u4F5C\u4E3A\u65C5\u8D39\u3002\u5B8C\u6210\u8FD9\u4E9B\u518D\u6765\u627E\u6211\u3002"
  nextDialog: []
