  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_2_2
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u827E\u514B\u7279\u5148\u751F\uFF0C\u6211\u56DE\u6765\u4E86\u3002\u6211\u5E26\u56DE\u4E86\u4E00\u4E9B\u91CE\u732A\u548C\u5176\u4ED6\u730E\u7269\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u54E6\uFF0C\u4E9A\u745F\uFF01\u8FD9\u771F\u662F\u592A\u597D\u4E86\u3002\u4F60\u7684\u72E9\u730E\u6210\u679C\u4F1A\u8BA9\u6211\u4EEC\u7684\u51AC\u5929\u8FC7\u5F97\u66F4\u52A0\u8212\u9002\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6211\u5F88\u9AD8\u5174\u80FD\u5E2E\u5230\u5927\u5BB6\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u4F60\u7684\u5251\u672F\u548C\u5C04\u672F\u5DF2\u7ECF\u975E\u5E38\u51FA\u8272\uFF0C\u6211\u4E3A\u4F60\u611F\u5230\u9A84\u50B2\u3002\u4F60\u548C\u6211\u7684\u513F\u5B50\u51EF\u5F88\u50CF\uFF0C\u4ED6\u5C0F\u65F6\u5019\u4E5F\u662F\u8FD9\u6837\uFF0C\u73B0\u5728\u5DF2\u7ECF\u662F\u4E00\u4E2A\u4F1F\u5927\u7684\u9A91\u58EB\u4E86\u3002\u6211\u76F8\u4FE1\uFF0C\u4F60\u5C06\u6765\u4E5F\u4F1A\u50CF\u51EF\u4E00\u6837\u6210\u4E3A\u4E00\u540D\u51FA\u8272\u7684\u9A91\u58EB\u3002"
  - name: "\u4E9A\u745F"
    content: "\u8C22\u8C22\u60A8\uFF0C\u827E\u514B\u7279\u5148\u751F\u3002\u6211\u4F1A\u52AA\u529B\u7684\u3002\u6811\u6797\u91CC\u6765\u4E86\u4E00\u4E9B\u81EA\u79F0\u730E\u6237\u7684\u4EBA\uFF0C\u4ED6\u4EEC\u662F\u5F88\u5F3A\u7684\u6B66\u58EB\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u5BF9\u4E86\uFF0C\u4F60\u5728\u5C71\u91CC\u78B0\u5230\u7684\u90A3\u4E9B\u964C\u751F\u4EBA\uFF0C\u6211\u975E\u5E38\u62C5\u5FC3\u3002\u8FD9\u4E2A\u6751\u5B50\u4E00\u76F4\u5F88\u5E73\u9759\uFF0C\u5F88\u5C11\u6709\u5916\u4EBA\u4F1A\u6765\u8FD9\u91CC\uFF0C\u5916\u6765\u7684\u964C\u751F\u4EBA\u53EF\u80FD\u4F1A\u5E26\u6765\u9EBB\u70E6\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6211\u660E\u767D\u3002\u6211\u4F1A\u4FDD\u6301\u8B66\u60D5\u7684\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u4ECA\u5929\u6751\u91CC\u6765\u4E86\u4E00\u4E2A\u4FE1\u4F7F\uFF0C\u5F20\u8D34\u4E86\u4E00\u4EFD\u65B0\u7684\u5E03\u544A\u3002\u4F60\u6216\u8BB8\u5E94\u8BE5\u53BB\u770B\u770B\uFF0C\u53EF\u80FD\u662F\u5173\u4E8E\u738B\u56FD\u7684\u91CD\u8981\u6D88\u606F\u3002"
  - name: "\u4E9A\u745F"
    content: "\u65B0\u7684\u5E03\u544A\uFF1F\u6211\u73B0\u5728\u5C31\u53BB\u770B\u770B\u3002"
  nextDialog: []
  dialogEvent: 
