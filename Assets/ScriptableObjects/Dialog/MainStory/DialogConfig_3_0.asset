  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_3_0
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u2026\u2026\u8FD9\u4E2A\u6751\u5E84\uFF0C\u53D1\u751F\u4E86\u4EC0\u4E48\uFF1F"
  - name: "\u4E9A\u745F"
    content: "\u6D3B\u7740\u7684\u4EBA\u2026\u2026\u53BB\u4E86\u54EA\u91CC\uFF1F"
  - name: "\u53D7\u4F24\u7684\u58EB\u5175"
    content: "\uFF08\u54B3\u55FD\uFF09"
  - name: "\u53D7\u4F24\u7684\u58EB\u5175"
    content: "\u8001\u56FD\u738B\u5DF2\u6B7B\u2026\u2026\u4E16\u754C\u518D\u4E00\u6B21\u7834\u788E\uFF0C\u6050\u6016\u7684\u9ED1\u6697\u9B54\u6CD5\u7B3C\u7F69"
  - name: "\u53D7\u4F24\u7684\u58EB\u5175"
    content: "\u683C\u96F7\u65AF\u5927\u4EBA\u547D\u6211\u4EEC\u524D\u6765\uFF0C\u4EE5\u5251\u4E4B\u540D\u2026\u2026\u8BA9\u4ED6\u4EEC\u5B89\u606F\u3002"
  - name: "\u53D7\u4F24\u7684\u58EB\u5175"
    content: "\u683C\u96F7\u65AF\u5927\u4EBA\u547D\u6211\u4EEC\u524D\u6765\uFF0C\u4EE5\u5251\u4E4B\u540D\u2026\u2026\u8BA9\u4ED6\u4EEC\u5B89\u606F\u3002"
  - name: "\u4E9A\u745F"
    content: "\u9ED1\u6697\u9B54\u6CD5\uFF1F\u8FD9\u662F\u4EC0\u4E48"
  - name: "\u53D7\u4F24\u7684\u58EB\u5175"
    content: "\u8FD9\u662F\u7687\u5BAB\u4E2D\u7684\u7981\u5FCC\uFF0C\u8574\u85CF\u5728\u77F3\u4E2D\u5251\u4E2D\uFF0C\u638C\u63E1\u4E86\u6B64\u7981\u5FCC\u4E4B\u529B\uFF0C\u5C31\u5F97\u4EE5\u638C\u63E1\u5929\u4E0B\u3002"
  - name: "\u53D7\u4F24\u7684\u58EB\u5175"
    content: "\u4F46\u8001\u56FD\u738B\u7684\u66B4\u6BD9\uFF0C\u8BA9\u8FD9\u80A1\u6765\u81EA\u8FDC\u53E4\u7684\u529B\u91CF\u91CA\u653E\u4E86\u51FA\u6765\uFF0C\u6240\u5230\u4E4B\u5904\u5BF8\u8349\u4E0D\u751F\u3002"
  - name: "\u53D7\u4F24\u7684\u58EB\u5175"
    content: "\u4F1F\u5927\u7684\u6885\u6797\u4F3C\u4E4E\u6B63\u5728\u5BFB\u627E\u7EE7\u627F\u4EBA\uFF0C\u4E3A\u4E86\u7EC8\u6B62\u8FD9\u4E2A\u4E71\u4E16\u3002"
  - name: "\u4E9A\u745F"
    content: "\uFF08\u6885\u6797\uFF1F\u4E0D\u662F\u6211\u5C71\u6D1E\u4E2D\u9047\u5230\u7684\u90A3\u4E2A\u795E\u79D8\u4EBA\u5417\uFF0C\u7EE7\u627F\u4EBA\uFF1F\u96BE\u9053......?\uFF09"
  - name: "\u53D7\u4F24\u7684\u58EB\u5175"
    content: "\uFF08\u75DB\u82E6\u5730\u54B3\u55FD\uFF09"
  - name: "\u53D7\u4F24\u7684\u58EB\u5175"
    content: "\u5E2E\u5E2E\u6211\u4EEC\u5427\uFF0C\u5E74\u8F7B\u7684\u6218\u58EB\uFF0C\u683C\u96F7\u65AF\u5927\u4EBA\u4E5F\u5FEB\u652F\u6491\u4E0D\u4F4F\u4E86......"
  nextDialog: []
