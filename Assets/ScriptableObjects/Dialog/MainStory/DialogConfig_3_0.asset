  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_3_0
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u53D1\u751F\u4E86\u4EC0\u4E48\u4E8B\uFF1F"
  - name: "\u6751\u6C111"
    content: "\u90A3\u91CC\u6709\u4E2A\u4FE1\u4F7F\u521A\u5F20\u8D34\u4E86\u4E00\u4EFD\u5E03\u544A\uFF0C\u8BF4\u7684\u662F\u56FD\u738B\u7684\u6B7B\u8BAF\uFF0C\u8FD8\u6709\u6BD4\u6B66\u9009\u56FD\u738B\u7684\u6D88\u606F\u3002"
  - name: "\u4E9A\u745F"
    content: "\u56FD\u738B\u53BB\u4E16\u4E86\uFF1F"
  - name: "\u4FE1\u4F7F"
    content: "\u662F\u7684\uFF0C\u56FD\u738B\u53BB\u4E16\u4E86\uFF0C\u6CA1\u6709\u7559\u4E0B\u7EE7\u627F\u4EBA\u3002\u73B0\u5728\uFF0C\u9A91\u58EB\u4EEC\u90FD\u524D\u5F80\u9996\u90FD\u53C2\u52A0\u6BD4\u6B66\uFF0C\u4E89\u593A\u738B\u4F4D\u3002"
  - name: "\u6751\u6C112"
    content: "\u6751\u5E84\u9644\u8FD1\u6CA1\u6709\u9A91\u58EB\u4FDD\u62A4\u4E86\u3002\u6700\u8FD1\u76D7\u532A\u56DB\u8D77\uFF0C\u6CA1\u4EBA\u4E3B\u6301\u6B63\u4E49\uFF0C\u6211\u4EEC\u8BE5\u600E\u4E48\u529E\u5462\uFF1F"
  - name: "\u4E9A\u745F"
    content: "\u6211\u4F1A\u4FDD\u62A4\u8FD9\u4E2A\u6751\u5E84\u3002\u6211\u4EEC\u4E0D\u80FD\u8BA9\u76D7\u532A\u5371\u5BB3\u6211\u4EEC\u7684\u5BB6\u56ED\u3002"
  - name: "\u6751\u6C113"
    content: "\u4E9A\u745F\uFF01\u4F60\u771F\u662F\u6211\u4EEC\u7684\u82F1\u96C4\u3002"
  - name: "\u6751\u6C114"
    content: "\u662F\u554A\uFF0C\u4ECA\u5929\u7684\u730E\u7269\u592A\u53CA\u65F6\u4E86\uFF01\u8FD9\u4E2A\u51AC\u5929\u5927\u5BB6\u4E0D\u4F1A\u6328\u997F\u4E86\u3002\u5982\u679C\u4F60\u9700\u8981\u5E2E\u52A9\uFF0C\u6211\u4EEC\u90FD\u4F1A\u6765\u5E2E\u4F60\u7684\u3002"
  nextDialog: []
