--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_2_0
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u6211\u662F\u8C01\uFF1F\u2026\u2026 \u4E3A\u4EC0\u4E48\u4F1A\u5728\u8FD9\u91CC\uFF1F"
  - name: "\u964C\u751F\u4EBA"
    content: "\u4E0D\u5FC5\u60CA\u614C\uFF0C\u5E74\u8F7B\u7684\u6218\u58EB\u3002\u4F60\u5E76\u975E\u610F\u5916\u6765\u5230\u8FD9\u91CC\u3002"
  - name: "\u4E9A\u745F"
    content: "\u4F60\u662F\u8C01\uFF1F\u6211\u2026\u2026 \u6211\u4EC0\u4E48\u90FD\u4E0D\u8BB0\u5F97\u4E86\u3002\u6211\u7684\u540D\u5B57\uFF0C\u6211\u7684\u8FC7\u53BB\u2026\u2026
      \u5168\u90FD\u4E00\u7247\u7A7A\u767D\u3002"
  - name: "\u964C\u751F\u4EBA"
    content: "\u6211\u662F\u6885\u6797\u3002\u81F3\u4E8E\u4F60\u662F\u8C01 \u2014\u2014
      \u7B54\u6848\u4E0D\u5728\u4F60\u7684\u8BB0\u5FC6\u91CC\uFF0C\u800C\u5728\u4F60\u7684\u547D\u8FD0\u4E2D\u3002"
  - name: "\u4E9A\u745F"
    content: "\u8FD9\u91CC\u53D1\u751F\u8FC7\u4EC0\u4E48\uFF1F\u90A3\u4E9B\u7834\u788E\u7684\u753B\u9762\u2026\u2026
      \u662F\u6211\u7684\u5E7B\u89C9\u5417\uFF1F"
  - name: "\u6885\u6797"
    content: "\u8FD9\u7247\u571F\u5730\u6B63\u5728\u5D29\u574F\u3002\u5C24\u745F\u738B\u901D\u53BB\uFF0C\u738B\u6743\u65C1\u843D\uFF0C\u9886\u4E3B\u6DF7\u6218\uFF0C\u761F\u75AB\u8513\u5EF6\u2026\u2026
      \u767E\u59D3\u5728\u9ED1\u6697\u4E2D\u54C0\u568E\uFF0C\u795E\u660E\u5DF2\u7136\u6C89\u9ED8\u3002"
  - name: "\u6885\u6797"
    content: "\u4F60\u5E76\u975E\u666E\u901A\u7684\u6D41\u6D6A\u8005\u3002\u4F60\u662F\u88AB\u9009\u4E2D\u7684\u4EBA
      \u2014\u2014 \u552F\u4E00\u80FD\u7EC8\u7ED3\u8FD9\u573A\u707E\u96BE\uFF0C\u91CD\u632F\u738B\u56FD\u79E9\u5E8F\u7684\u4EBA\u3002"
  - name: "\u4E9A\u745F"
    content: "\u9009\u4E2D\u7684\u4EBA\uFF1F\u6240\u4EE5\u6211\u9700\u8981\u505A\u4EC0\u4E48\uFF1F"
  - name: "\u6885\u6797"
    content: "\u8BB0\u5FC6\u4F1A\u56DE\u5F52\uFF0C\u4F46\u73B0\u5728\uFF0C\u4F60\u9700\u8981\u77E5\u9053\u66F4\u91CD\u8981\u7684\u4E8B\u3002\u5728\u4F26\u6566\u7684\u6559\u5802\u5E7F\u573A\uFF0C\u77D7\u7ACB\u7740\u4E00\u628A\u77F3\u4E2D\u5251\u3002\u5B83\u662F\u795E\u660E\u610F\u5FD7\u7684\u5177\u8C61\u5316\uFF0C\u662F\u738B\u6743\u7684\u8C61\u5F81
      \u2014\u2014 \u53EA\u6709\u62D4\u51FA\u5B83\u7684\u4EBA\uFF0C\u624D\u80FD\u6210\u4E3A\u771F\u6B63\u7684\u738B\uFF0C\u7EC8\u7ED3\u6218\u4E71\uFF0C\u5E26\u6765\u548C\u5E73\u3002\n"
  - name: "\u6885\u6797"
    content: "\u52A8\u8EAB\u5427\uFF0C\u5E74\u8F7B\u7684\u6218\u58EB\u3002\n\u8FD9\u6C89\u6CA6\u4E8E\u9ED1\u6697\u4E0E\u707E\u5384\u7684\u738B\u571F\uFF0C\u65E9\u5DF2\u4E3A\u4F60\u94FA\u5C31\u5BBF\u547D\u4E4B\u8DEF\uFF0C\u53EA\u5F85\u4F60\u524D\u5F80\uFF0C\u627F\u63A5\u90A3\u5C5E\u4E8E\u4F60\u7684\u300C\u738B\u6743\u300D"
  nextDialog: []
