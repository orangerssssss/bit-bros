  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ae80d34c3c968a646a29d7877872a6eb, type: 3}
  m_Name: DialogConfig_1_0
  m_EditorClassIdentifier: 
  contents:
  - name: "\u4E9A\u745F"
    content: "\u827E\u514B\u7279\u5148\u751F\uFF0C\u6211\u542C\u8BF4\u60A8\u5728\u627E\u6211\uFF1F"
  - name: "\u827E\u514B\u7279"
    content: "\u4E9A\u745F\uFF0C\u6765\u5F97\u6B63\u597D\uFF0C\u6211\u6709\u4E8B\u548C\u4F60\u5546\u91CF\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u8FD9\u4E2A\u51AC\u5929\u7279\u522B\u4E25\u9177\uFF0C\u6751\u91CC\u7684\u98DF\u7269\u50A8\u5907\u4E0D\u8DB3\uFF0C\u6709\u4E9B\u5BB6\u5EAD\u5DF2\u7ECF\u5F00\u59CB\u611F\u5230\u7F3A\u7CAE\u3002"
  - name: "\u4E9A\u745F"
    content: "\u8FD9\u786E\u5B9E\u662F\u4E2A\u95EE\u9898\u3002\u6211\u4EEC\u9700\u8981\u66F4\u591A\u7684\u98DF\u7269\u6765\u5E2E\u52A9\u4ED6\u4EEC\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u662F\u7684\u3002\u6211\u60F3\u8BA9\u4F60\u53BB\u5C71\u91CC\u6253\u730E\uFF0C\u5C3D\u53EF\u80FD\u591A\u5E26\u4E9B\u5927\u578B\u730E\u7269\u56DE\u6765\u3002\u4F60\u7684\u6B66\u827A\u8DB3\u4EE5\u5E94\u5BF9\u5C71\u91CC\u7684\u6311\u6218\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6211\u660E\u767D\u4E86\uFF0C\u6211\u4F1A\u5C3D\u6211\u6240\u80FD\u3002\u6211\u4E0D\u4F1A\u8BA9\u6751\u6C11\u5931\u671B\u7684\u3002"
  - name: "\u827E\u514B\u7279"
    content: "\u94C1\u5320\u4E3A\u4F60\u6253\u9020\u4E86\u65B0\u5251\u3002\u4ED6\u8BF4\u4F60\u7684\u529B\u91CF\u53C8\u6709\u4E86\u8FDB\u6B65\uFF0C\u9700\u8981\u4E00\u628A\u66F4\u9002\u5408\u4F60\u7684\u6B66\u5668\u3002\u53BB\u5427\uFF0C\u4E9A\u745F\u3002\u6751\u5B50\u7684\u672A\u6765\u5C31\u9760\u4F60\u4E86\u3002\u8BB0\u5F97\u5C0F\u5FC3\uFF0C\u5C71\u91CC\u7684\u91CE\u517D\u975E\u5E38\u5371\u9669\u3002"
  - name: "\u4E9A\u745F"
    content: "\u6211\u4F1A\u5C0F\u5FC3\u7684\u3002"
  nextDialog: []
